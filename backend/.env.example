# Backend environment variables
# Copy this file to .env and fill in your actual values

# Google Gemini API
GOOGLE_API_KEY=your_google_api_key_here

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
API_ENV=development

# CORS Settings
ALLOWED_ORIGINS=http://localhost,http://localhost:5173,http://localhost:3000

# Logging
LOG_LEVEL=INFO
